# HomeHub v2 — Environment Variables
#
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it contains secrets.
# See docs/ENV.md for full variable descriptions.

# Supabase project (safe to expose in the browser)
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth — client ID is safe for the browser
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Server-only secrets — NEVER prefix these with VITE_
# These are injected automatically into Edge Functions by Supabase.
# Set them in the Supabase Dashboard → Project Settings → Edge Functions.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# SUPABASE_JWT_SECRET=your-jwt-secret

# GitHub Actions secrets (set in repo Settings → Secrets → Actions)
# VITE_SUPABASE_URL — same as above, injected into build
# VITE_SUPABASE_ANON_KEY — same as above, injected into build
# The following are only needed for E2E tests (e2e.yml):
# SUPABASE_SERVICE_ROLE_KEY — service role key for seeding test data
# TEST_USER_EMAIL / TEST_USER_PASSWORD — primary test user credentials
# TEST_PARTNER_EMAIL / TEST_PARTNER_PASSWORD — partner test user credentials
# BASE_URL — URL of deployed preview/staging app
#
# Vercel deployment: configured separately in the Vercel dashboard via GitHub integration.
