# HomeHub v2 — Environment Variables
#
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it contains secrets.
# See docs/ENV.md for full variable descriptions.

# Supabase project (safe to expose in the browser)
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth — client ID is safe for the browser
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Server-only secrets — NEVER prefix these with VITE_
# These are injected automatically into Edge Functions by Supabase.
# Set them in the Supabase Dashboard → Project Settings → Edge Functions.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# SUPABASE_JWT_SECRET=your-jwt-secret
